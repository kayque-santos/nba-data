cat > .gitignore << 'EOF'
# ===== Credenciais e configs sensíveis =====
.env
.env.*
!.env.example
*.pem
*.key
profiles.yml

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ===== Virtual environments =====
venv/
env/
ENV/
.venv/

# ===== Airflow =====
logs/
airflow.cfg
airflow.db
webserver_config.py
standalone_admin_password.txt

# ===== dbt =====
target/
dbt_packages/
dbt_modules/

# ===== Docker =====
*.pid

# ===== Dados =====
data/bronze/*
data/silver/*
data/gold/*
*.parquet
*.csv
!data/bronze/.gitkeep
!data/silver/.gitkeep
!data/gold/.gitkeep

# ===== IDE / Editores =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== Sistema operacional =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Jupyter =====
.ipynb_checkpoints/
*.ipynb_checkpoints
EOF